<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.webber.notes-work-sync</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/bash</string>
      <string>/Users/webber/Notes-Work/.sync/sync_notes_to_icloud.sh</string>
    </array>

    <key>StartInterval</key>
    <integer>300</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/webber/Notes-Work/.sync/launchd.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/webber/Notes-Work/.sync/launchd.err.log</string>
  </dict>
</plist>
